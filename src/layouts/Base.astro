---
import { black, white, green, red, purple } from "../config/colors";
import { prose, headings, backArrow } from "../config/typography";
import {
  bodyPaddingBlockStart,
  bodyPaddingBlockEnd,
  bodyPaddingInlineStart,
  bodyPaddingInlineEnd,
} from "../config/layout";
import BackArrow from "../components/BackArrow.astro";
import Tombstone from "../components/Tombstone.astro";

interface Props {
  title?: string;
}

const { title = "Kevin Sullivan" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />

    <!--
     --- width=device-width = Don't use scaled down desktop-width pages
     ---
     --- viewport-fit=cover = Use full viewport, including safe areas
     ---                      occluded by browser chrome and screen notches
     -->
    <meta name="viewport" content="width=device-width, viewport-fit=cover" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
  </head>
  <body>
    <header>
      <BackArrow />
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <Tombstone />
    </footer>
  </body>
</html>

<!--
  -- Layout
  -->
<style>
  body {
    display: flex;
    flex-direction: column;
    gap: 8rem;

    max-width: 80rem; /* 1280px */
    margin: 0 auto;

    /*
     * Use full viewport, but prevent content from
     * being obscured by screen cutouts and
     * browser chrome
     */
    padding:
      var(--bodyPaddingBlockStart)
      var(--bodyPaddingInlineEnd)
      var(--bodyPaddingBlockEnd)
      var(--bodyPaddingInlineStart);

    /**
     * Allow footer room to hit the viewport's bottom on short pages
     *
     * Use `svh` as it allows the footer to display over any bottom browser
     * interface elements
     */
    min-height: 100svh;
  }

  main {
    /**
     * Allow footer to stay at bottom of viewport on short pages.
     *
     * An alternative could be to expand the footer instead, and
     * have the footer's tombstone aligned to the bottom.
     */
    flex-grow: 1;
  }

  @media print {
    header {
      display: none;
    }
  }
</style>

<!--
  -- Colors
  -->
<style is:global set:html={`
  :root {
    --white: ${white};
    --black: ${black};
    --green: ${green};
    --red: ${red};
    --purple: ${purple};
  }
`}></style>

<!--
  -- Typography
  -->
<style is:global set:html={`
  :root {
    --proseFontSize: ${prose.fontSize};
    --proseLineHeight: ${prose.lineHeight};
    --proseParagraphGap: ${prose.paragraphGap};
    --proseListGap: ${prose.listGap};
    --proseListMarginBlock: ${prose.listMarginBlock};
    --proseHeadingGap: ${prose.headingGap};
    --proseHeadingGapTop: ${prose.headingGapTop};
    --proseCodeFontSize: ${prose.codeFontSize};
    --proseCodeBlockGap: ${prose.codeBlockGap};
    --h1FontSize: ${headings.h1.fontSize};
    --h2FontSize: ${headings.h2.fontSize};
    --h3FontSize: ${headings.h3.fontSize};
    --h4FontSize: ${headings.h4.fontSize};
    --h5FontSize: ${headings.h5.fontSize};
    --h6FontSize: ${headings.h6.fontSize};
    --backArrowFontSize: ${backArrow.fontSize};
  }
`}></style>

<!--
  -- Layout
  -->
<style is:global set:html={`
  :root {
    --bodyPaddingBlockStart: ${bodyPaddingBlockStart};
    --bodyPaddingBlockEnd: ${bodyPaddingBlockEnd};
    --bodyPaddingInlineStart: ${bodyPaddingInlineStart};
    --bodyPaddingInlineEnd: ${bodyPaddingInlineEnd};
  }
`}></style>

<!--
  -- Color scheme
  -->
<style is:global>
  :root {
    color-scheme: light dark;
  }

  :root {
    --fg: var(--black);
    --bg: var(--white);
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --fg: var(--white);
      --bg: var(--black);
    }
  }

  :root {
    color: var(--fg);
    background: var(--bg);
  }
</style>

<!--
  -- CSS reset
  --
  -- Inspiration: https://www.joshwcomeau.com/css/custom-css-reset/
  -->
<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
  }

  * {
    margin: 0;

    /*
     * Remove browser's automatic half-leading block space
     *
     * Makes it way easier to align text with other elements
     * along the vertical axis.
     */
    text-box-edge: cap alphabetic;
    text-box-trim: trim-both;
  }

  /*
   * KaTeX uses many nested inline boxes with custom layout.
   * text-box-trim can collapse their block size, causing
   * multi-line equations to overlap adjacent content.
   */
  .katex-display,
  .katex,
  .katex * {
    text-box-edge: auto;
    text-box-trim: none;
  }

  :root {
    /*
     * System font stack
     *
     * See: https://systemfontstack.com
     */
    font-family: -apple-system, BlinkMacSystemFont, avenir next, avenir, segoe ui, helvetica neue, helvetica, Cantarell, Ubuntu, roboto, noto, arial, sans-serif;

    /*
     * Make macOS Safari font rendering consistent with:
     *
     * - Rest of macOS (no subpixel antialiasing)
     * - Other operating systems
     *
     * See: https://dbushell.com/2024/11/05/webkit-font-smoothing/
     */
    -webkit-font-smoothing: antialiased;
  }

  input, button, textarea, select {
    /* Consistent look and fix auto-zoom behavior on mobile */
    font: inherit;
  }

  p, h1, h2, h3, h4, h5, h6 {
    /* Soft fallback for words too long to fit the line */
    hyphens: auto;
  }

  p, li {
    /*
     * Follow WCAG recommendations, while allowing tighter
     * line heights for larger text
     */
    line-height: var(--proseLineHeight);

    /* Avoid orphan lines with a single word */
    text-wrap: pretty;
  }

  h1, h2, h3, h4, h5, h6 {
    /* Tightest, recommended line-height defined by font */
    line-height: 1;

    /* Make lines about equal length */
    text-wrap: balance;

    /* Get blockiest appearance we can get */
    font-weight: 900;
  }

  @media (prefers-color-scheme: dark) {
    h1, h2, h3, h4, h5, h6 {
      /*
       * Light-on-dark is punchier. Reduce weight a bit
       * to compensate.
       */
      font-weight: 800;
    }
  }

  img, picture, video, canvas, svg {
    display: block;
    max-width: 100%;
    height: auto;
  }
</style>
