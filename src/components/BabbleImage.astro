---
import { Picture, type LocalImageProps } from 'astro:assets'

export type Props = LocalImageProps

// biome-ignore lint/suspicious/noExplicitAny: `<Picture>` accepts a discriminated union (Local|Remote); TS can't validate a JSX spread against it under exactOptionalPropertyTypes
const { src, ...rest } = Astro.props as any
---

<Picture
  src={src}
  width={src.width / 2}
  formats={['avif']}
  layout="constrained"
  {...rest}
/>
