---
import type { HTMLAttributes } from 'astro/types'

export interface Props extends HTMLAttributes<'a'> {
  inline?: boolean;
}

const { inline = true, class: className, ...props } = Astro.props;
---

<!-- biome-ignore lint/a11y/useAnchorContent: content provided via slot -->
<a class:list={[className, { inline }]} {...props}><slot /></a>

<style>
  a {
    color: var(--purple);
    text-decoration: none;
    padding-bottom: 0.2em;
    border-bottom: 0.2em solid color-mix(in srgb, var(--purple) 30%, transparent);
  }

  /**
   * Opt out of the global `text-box-trim: trim-both` for
   * inline display contexts.
   *
   * Per the spec, text-box-trim on inline boxes only trims
   * painting (backgrounds/borders), not layout — the height
   * contribution stays based on line-height. Chrome follows
   * this, so our padding/border end up offset from the
   * descent line rather than the alphabetic baseline. Safari
   * applies the full trim to inlines too, which looks correct
   * but goes beyond the current spec.
   *
   * Resetting here avoids the Chrome discrepancy and lets the
   * parent block container's trim handle the line box. The
   * padding is also removed since the parent's trim already
   * accounts for the space between baseline and border.
   *
   * @see https://github.com/w3c/csswg-drafts/issues/10834#issuecomment-2578210039
   */
  a.inline {
    text-box-trim: none;
    padding-bottom: 0;
  }

  a:hover {
    border-bottom-color: var(--purple);
  }

  /*
   * Without text-box-trim (e.g. Firefox), the line box's leading
   * and descent already supply the visual gap between the baseline
   * and the border, so our padding stacks on top and looks bloated.
   */
  @supports not (text-box-trim: trim-both) {
    a:not(.inline) {
      padding-bottom: 0;
    }
  }
</style>
