---
const isHomepage = Astro.url.pathname === '/';
---

{isHomepage ? (
  <span class="logo">sullvn</span>
) : (
<a href="/" class="logo">
  <span>sullvn</span>
  <span class="arrow">↖</span>
</a>
)}

<style>
  .logo {
    display: flex;
    flex-direction: column;

    font-size: var(--logoFontSize);
    font-weight: 900;
    text-transform: uppercase;
    color: inherit;
    text-decoration: none;

    position: absolute;
    top: calc(-0.65 * var(--logoFontSize));

    /* Avoid back arrow being obscured by screen cutout */
    left: env(safe-area-inset-left);

    max-width: 100%;
    overflow-x: hidden;
  }

  span.logo {
    display: block;

    /* Avoid overflow cutoff of text descenders */
    padding-bottom: 1rem;
  }

  a.logo {
    display: flex;
    flex-direction: column;
    align-items: start;

transition: transform 0.4s cubic-bezier(0, 0, 0.35, 1), color 0.4s cubic-bezier(0, 0, 0.35, 1);
  }

  a.logo:hover {
    transform: translateY(calc(0.05 * var(--logoFontSize)));
    color: var(--purple);
  }

  /*
   * Include specific `a` selector to override
   * built-in `a:any-link`, `a:any-link:active`
   */
  .logo, a.logo {
    color: color-mix(in oklab, var(--purple) 25%, var(--bg) 80%);
    text-decoration: none;
  }

  .arrow {
    font-size: var(--h1FontSize);
    color: var(--purple);

    margin: .5rem;
  }
</style>
