---
import Anchor from './Anchor.astro';

const isHomepage = Astro.url.pathname === '/';
---

{!isHomepage && (
  <Anchor href="/" class="back-arrow" style="border-bottom:none;padding-bottom:0">↖</Anchor>
)}

<style>
  .back-arrow {
    position: absolute;
    top: 0;

    /* Avoid back arrow being obscured by screen cutout */
    left: env(safe-area-inset-left);

    margin: .5rem;

    font-size: var(--backArrowFontSize);
    font-weight: 900;
    text-transform: uppercase;

  }
</style>
