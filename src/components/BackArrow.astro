---
import Anchor from './Anchor.astro';

const { pathname } = Astro.url;
const isHomepage = pathname === '/' || pathname === '/index.html';
---

{!isHomepage && (
  <Anchor href="/" class="back-arrow" inline={false}>↖</Anchor>
)}

<style>
  .back-arrow {
    position: absolute;
    top: 0;

    /* Avoid back arrow being obscured by screen cutout */
    left: env(safe-area-inset-left);

    margin: .5rem;

    font-size: var(--backArrowFontSize);
    font-weight: 900;
    text-transform: uppercase;

    border-bottom: none;
    padding-bottom: 0;
  }

  /*
   * Without text-box-trim (e.g. Firefox), line-height adds vertical
   * space above the glyph. Tightening it pulls the arrow up to the
   * visual top of its container.
   */
  @supports not (text-box-trim: trim-both) {
    .back-arrow {
      line-height: 0.7;
    }
  }
</style>
