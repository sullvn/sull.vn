---
import Base from '../layouts/Base.astro';
import BabbleLink from '../components/BabbleLink.astro';
import BabblesNav from '../components/BabblesNav.astro';
import Prose from '../components/Prose.astro';
import H2 from '../components/H2.astro';
---

<Base>
  <div class="home">
    <section class="fun">
    </section>

    <section class="intro">
      <Prose>Oh, hey!</Prose>
      <Prose>I'm Kevin Sullivan.</Prose>
      <Prose>
        I do stuff at the intersection of technology and
        creativity. Sometimes I write about that.
      </Prose>
      <Prose>Here's my GitHub, resume, and email. Say hello!</Prose>
      <Prose>Bloop.</Prose>
    </section>

    <section class="babbles">
      <H2>Babbles</H2>
      <BabblesNav>
        <BabbleLink
          href="/babbles/example-title"
          title="Notes from Hyper-Dimensional Spelunking"
          date="2018-08-24"
        />
        <BabbleLink
          href="/babbles/example-title"
          title="Notes from Hyper-Dimensional Spelunking"
          date="2018-08-24"
        />
        <BabbleLink
          href="/babbles/example-title"
          title="Notes from Hyper-Dimensional Spelunking"
          date="2018-08-24"
        />
      </BabblesNav>
    </section>
  </div>
</Base>

<style>
  .home {
    display: grid;

    grid-template-columns: 1fr 1fr;
    grid-template-areas:
      "fun     intro"
      "babbles babbles";

    row-gap: 3rem;
  }

  .fun {
    grid-area: fun;
   }

  .intro {
    grid-area: intro;
  }

  .babbles {
    grid-area: babbles;
    display: flex;
    flex-direction: column;
    gap: var(--proseParagraphGap);
  }
</style>
