---
import Base from '../layouts/Base.astro';
import BabbleLink from '../components/BabbleLink.astro';
---

<Base>
  <div class="home">
    <section class="fun">
    </section>

    <section class="intro">
      <p>Oh, hey!</p>
      <p>I'm Kevin Sullivan.</p>
      <p>
        I do stuff at the intersection of technology and
        creativity. Sometimes I write about that.
      </p>
      <p>Here's my GitHub, resume, and email. Say hello!</p>
      <p>Bloop.</p>
    </section>

    <section class="babbles">
      <h2>Babbles</h2>
      <nav>
        <ol>
          <BabbleLink
            href="/babbles/example-title"
            title="Notes from Hyper-Dimensional Spelunking"
            date="2018-08-24"
          />
