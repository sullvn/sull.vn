</Base>

<style>
  .home {
    display: grid;

    grid-template-columns: 1fr 1fr;
    grid-template-areas:
      "fun     intro"
      "babbles babbles"
      "resume resume";

    row-gap: 3rem;
  }

  h2 {
    font-size: 3rem;
  }

  .fun {
    grid-area: fun;
   }

  .intro {
    grid-area: intro;
   }

  .babbles {
    grid-area: babbles;
  }

  .resume {
    grid-area: resume;
  }
</style>
