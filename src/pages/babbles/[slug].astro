---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Anchor from '../../components/Anchor.astro';
import Heading from '../../components/Heading.astro';
import { formatDate, toIsoDay } from '../../utils/date'
import 'katex/dist/katex.css';

export async function getStaticPaths() {
  const babbles = await getCollection('babbles');
  return babbles.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const date = toIsoDay(entry.data.date)
---

<Base title={entry.data.title}>
  <article>
    <header>
      <Heading level={1}>{entry.data.title}</Heading>
      <time datetime={date}>{formatDate(date)}</time>
    </header>

    <section class="content">
      <Content components={{ a: Anchor }} />
    </section>
  </article>
</Base>

<style>
  article {
    display: flex;
    flex-direction: column;
    gap: 8rem;
    container-type: inline-size;
  }

  @container (max-width: 640px) {
    header :global(h1) {
      font-size: var(--h2FontSize);
    }
  }

  header {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    text-align: center;
  }

  header time {
    font-size: var(--h5FontSize);
  }

  .content :global(p) {
    max-width: 60rch;
    font-size: var(--proseFontSize);
    margin-bottom: var(--proseParagraphGap);
    margin-inline: auto;
  }

  .content :global(:is(h1, h2, h3, h4, h5, h6)) {
    max-width: 70rch;
    margin-inline: auto;
    margin-top: var(--proseHeadingGapTop);
    margin-bottom: var(--proseHeadingGap);
  }

  .content :global(:is(img, picture, figure, svg, video, canvas, iframe)) {
    margin-inline: auto;
    margin-block: var(--proseCodeBlockGap);
  }

  .content :global(iframe) {
    display: block;
  }

  .content :global(p:has(img)) {
    max-width: none;
    margin-block: 0;
  }

  .content :global(:is(ul, ol)) {
    max-width: 60rch;
    margin-inline: auto;
    font-size: var(--proseFontSize);
    margin-block: var(--proseListMarginBlock);
    padding-inline-start: 3ch;
    list-style-position: outside;
    display: flex;
    flex-direction: column;
    gap: var(--proseListGap);
  }

  .content :global(.astro-code) {
    width: max-content;
    min-width: min(70rch, 100%);
    max-width: 100%;

    margin-inline: auto;
    margin-block: var(--proseCodeBlockGap);
    padding-block: 1ex;

    font-size: var(--proseCodeFontSize);
    font-family: Menlo, Consolas, Monaco, 'Adwaita Mono', 'Liberation Mono', 'Lucida Console', monospace;
    line-height: calc(1em + 0.5rem);

    /* biome-ignore lint/complexity/noImportantStyles: override Shiki inline styles */
    background: transparent !important;
    /* biome-ignore lint/complexity/noImportantStyles: override Shiki inline styles */
    color: inherit !important;
    /*
     * `overflow-x: auto` for horizontal scrolling on wide code.
     *
     * `overflow-y: clip` to suppress a spurious vertical scrollbar
     * in Chrome, caused by subpixel `line-height` rounding: setting
     * any `overflow-x` other than `visible` computes `overflow-y`
     * to `auto` per spec, and Chrome's font metrics can push content
     * a fraction of a pixel past the box.
     */
    overflow: auto clip;
  }

  .content :global(.katex-display) {
    margin-block: var(--proseCodeBlockGap);
  }

  @media (prefers-color-scheme: dark) {
    .content :global([data-invert-on-dark]) {
      filter: invert(1) hue-rotate(180deg);
    }
  }

  @media (prefers-color-scheme: light) {
    .content :global([data-monochrome-blend]) {
      mix-blend-mode: darken;
    }
  }

  @media (prefers-color-scheme: dark) {
    .content :global([data-invert-on-dark][data-monochrome-blend]) {
      mix-blend-mode: lighten;
    }
  }

  @media (prefers-color-scheme: dark) {
    .content :global(.astro-code span) {
      /* biome-ignore lint/complexity/noImportantStyles: override Shiki inline styles */
      color: var(--shiki-dark) !important;
      /* biome-ignore lint/complexity/noImportantStyles: override Shiki inline styles */
      font-style: var(--shiki-dark-font-style) !important;
      /* biome-ignore lint/complexity/noImportantStyles: override Shiki inline styles */
      font-weight: var(--shiki-dark-font-weight) !important;
      /* biome-ignore lint/complexity/noImportantStyles: override Shiki inline styles */
      text-decoration: var(--shiki-dark-text-decoration) !important;
    }
  }

  @media (prefers-color-scheme: light) {
    .content :global(.astro-code span) {
      /* biome-ignore lint/complexity/noImportantStyles: override Shiki inline styles */
      font-style: var(--shiki-light-font-style) !important;
      /* biome-ignore lint/complexity/noImportantStyles: override Shiki inline styles */
      font-weight: var(--shiki-light-font-weight) !important;
      /* biome-ignore lint/complexity/noImportantStyles: override Shiki inline styles */
      text-decoration: var(--shiki-light-text-decoration) !important;
    }
  }
</style>
